FROM node:22-alpine@sha256:4d64b49e6c891c8fc821007cb1cdc6c0db7773110ac2c34bf2e6960adef62ed3

WORKDIR /app

RUN addgroup -S -g 10001 appgroup \
  && adduser -S -D -h /home/appuser -u 10001 -G appgroup appuser \
  && mkdir -p /home/appuser/.cache/node/corepack \
  && chown -R 10001:10001 /home/appuser

ENV HOME=/home/appuser
ENV COREPACK_HOME=/home/appuser/.cache/node/corepack

RUN corepack enable

COPY package.json yarn.lock .yarnrc.yml ./
RUN yarn install --immutable

COPY --chown=10001:10001 . .
RUN chown -R 10001:10001 /app
USER 10001:10001

EXPOSE 8080

CMD ["yarn", "dev", "--host", "0.0.0.0", "--port", "8080"]
